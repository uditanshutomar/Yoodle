    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.42.0",
    "@types/ssh2": "^1.15.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.1",
