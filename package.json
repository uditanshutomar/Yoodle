{
  "name": "yoodle-landing",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,backend -c cyan,yellow \"next dev\" \"node --require ts-node/register --require tsconfig-paths/register backend-service.ts\"",
    "dev:next": "next dev",
    "dev:backend": "node --require ts-node/register --require tsconfig-paths/register backend-service.ts",
    "build": "next build",
    "start": "next start",
    "start:backend": "NODE_ENV=production node --require ts-node/register --require tsconfig-paths/register backend-service.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
