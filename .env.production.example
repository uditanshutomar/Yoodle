# =====================================================================
# Yoodle — Production Environment
# =====================================================================
# Copy this to .env.production and fill in all values.
# =====================================================================

# ── Edition ─────────────────────────────────────────────────────────
# "community" = free self-hosted (default)
# "cloud"     = managed SaaS with premium features
YOODLE_EDITION=community

# ── App Config ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Authentication ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ── Database ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/yoodle?retryWrites=true&w=majority

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=changeme

# ── LiveKit (real-time media) ────────────────────────────────────────
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── AI / LLM (pick one provider) ───────────────────────────────────
# Providers: gemini | claude | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Voice (STT / TTS — pick providers) ─────────────────────────────
# STT providers: browser | deepgram | whisper
# TTS providers: elevenlabs | openai
STT_PROVIDER=deepgram
TTS_PROVIDER=elevenlabs
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# ── Storage (S3-compatible — for recordings) ─────────────────────────
S3_ENDPOINT=https://ewr1.vultrobjects.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=yoodle-recordings
S3_REGION=ewr1

# ── TURN Server (WebRTC NAT traversal) ──────────────────────────────
TURN_SERVER_URL=turn:YOUR_SERVER_IP:3478
TURN_SECRET=changeme

# ── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@your-domain.com

# ── Vultr (VM provisioning — optional) ──────────────────────────────
VULTR_API_KEY=
VULTR_SSH_KEY_ID=
