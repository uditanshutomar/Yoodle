# =====================================================================
# Yoodle — Environment Variables
# =====================================================================
# Copy this file to .env.local (dev) or .env.production (prod) and
# fill in the values. Never commit real secrets to version control.
# =====================================================================

# ── Edition ─────────────────────────────────────────────────────────
# "community" = free self-hosted (default)
# "cloud"     = managed SaaS with premium features
YOODLE_EDITION=community

# ── App Config ───────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Authentication ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Database ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/yoodle

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LiveKit (real-time media) ────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ── AI / LLM ────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
# Optional: override Gemini model (default: gemini-3.1-pro-preview)
# GEMINI_MODEL=gemini-3.1-pro-preview

# ── Speech-to-Text (STT) ────────────────────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── Google Maps ──────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Sentry (error monitoring) ──────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Cron / Scheduled Jobs ──────────────────────────────────────────
# Secret for authenticating cron endpoint calls
# CRON_SECRET=your-cron-secret-here

# ── Base URL fallback ──────────────────────────────────────────────
# Used for generating absolute links (calendar invites, emails, etc.)
# Defaults to NEXT_PUBLIC_APP_URL if unset
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────────────
# LOG_LEVEL=info

# ── Health Endpoint Detail ────────────────────────────────────────
# Secret header value to include service details in /api/health response
# HEALTH_DETAIL_SECRET=your-health-detail-secret
