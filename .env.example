# =====================================================================
# Yoodle — Environment Variables
# =====================================================================
# Copy this file to .env.local (dev) or .env.production (prod) and
# fill in the values. Never commit real secrets to version control.
# =====================================================================

# ── Edition ─────────────────────────────────────────────────────────
# "community" = free self-hosted (default)
# "cloud"     = managed SaaS with premium features
YOODLE_EDITION=community

# ── App Config ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Authentication ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=7d

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Database ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/yoodle

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ── LiveKit (real-time media) ────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ── AI / LLM (pick one provider) ───────────────────────────────────
# Providers: gemini | claude | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Voice (STT / TTS — pick providers) ─────────────────────────────
# STT providers: browser | elevenlabs | deepgram | whisper
# TTS providers: elevenlabs | openai
STT_PROVIDER=browser
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── TURN Server (WebRTC NAT traversal) ──────────────────────────────
TURN_SERVER_URL=turn:localhost:3478
TURN_USERNAME=yoodle
TURN_CREDENTIAL=changeme

# ── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@localhost

# ── Vultr (VM provisioning) ─────────────────────────────────────────
VULTR_API_KEY=
VULTR_SSH_KEY_ID=
