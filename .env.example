# =====================================================================
# Yoodle — Environment Variables
# =====================================================================
# Copy this file to .env.local (dev) or .env.production (prod) and
# fill in the values. Never commit real secrets to version control.
# =====================================================================

# ── Edition ─────────────────────────────────────────────────────────
# "community" = free self-hosted (default)
# "cloud"     = managed SaaS with premium features
YOODLE_EDITION=community

# ── App Config ───────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Authentication ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Database ─────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/yoodle

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LiveKit (real-time media) ────────────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ── AI / LLM ────────────────────────────────────────────────────────
# Providers: gemini | claude | openai
LLM_PROVIDER=gemini
LLM_API_KEY=your-llm-api-key-here
GEMINI_API_KEY=your-gemini-api-key

# ── Speech-to-Text (STT) ────────────────────────────────────────────
# Providers: browser | elevenlabs | deepgram | whisper
STT_PROVIDER=browser
# STT_API_KEY=your-stt-api-key
# DEEPGRAM_API_KEY=your-deepgram-api-key
# ELEVEN_LABS_API_KEY=your-elevenlabs-api-key
# OPENAI_API_KEY=your-openai-api-key

# ── Logging ──────────────────────────────────────────────────────────
# LOG_LEVEL=info
